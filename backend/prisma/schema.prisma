// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  role      UserRole 
  totalXp   Int      @default(0) @map("total_xp")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  progress         Progress[]
  materialProgress MaterialProgress[]
  assignments      Assignment[]
  attempts         Attempt[]
  badges           UserBadge[]
  reason           Reason[]
  response         Response[]

  @@map("users")
}

enum UserRole {
  ADMIN     @map("admin")
  DOSEN     @map("dosen")
  MAHASISWA @map("mahasiswa")

  @@map("user_role")
}

// ============================================
// LEARNING CONTENT
// ============================================

model Level {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  xpRequired  Int      @map("xp_required")
  description String?  @db.Text
  iconName    String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  materials    Material[]
  challenges   Challenge[]
  progress     Progress[]
  assignments  Assignment[]

  @@map("levels")
}

model Material {
  id        Int      @id @default(autoincrement())
  levelId   Int      @map("level_id")
  title     String   @db.VarChar(200)
  content   String   @db.Text
  order     Int      @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  level            Level              @relation(fields: [levelId], references: [id], onDelete: Cascade)
  materialProgress MaterialProgress[]

  @@index([levelId, order], name: "idx_materials_level_order")
  @@map("materials")
}

// ============================================
// CHALLENGES
// ============================================

model Challenge {
  id              Int             @id @default(autoincrement())
  levelId         Int             @map("level_id")
  title           String          @db.VarChar(200)
  description     String          @db.Text
  difficulty      Difficulty
  method          ChallengeMethod
  idealTime       Int             @map("ideal_time")
  xpBase          Int             @map("xp_base") @db.SmallInt
  content         Json?           @map("content")
  starterCode     String?         @map("starter_code") @db.Text
  testCases       Json?           @map("test_cases")
  hint            String?         @db.Text
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  level        Level          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  assignments  Assignment[]
  attempts     Attempt[]

  @@index([levelId, difficulty], name: "idx_challenges_level_difficulty")
  @@index([levelId, isActive], name: "idx_challenges_active")
  @@map("challenges")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD

  @@map("difficulty")
}

enum ChallengeMethod {
  DRAG_AND_DROP  @map("drag_and_drop")
  CODING_MANUAL  @map("coding_manual")
  FIX_THE_BUG    @map("fix_the_bug")

  @@map("challenge_method")
}

// ============================================
// USER PROGRESS TRACKING
// ============================================

model Progress {
  id         Int     @id @default(autoincrement())
  userId     Int     @map("user_id")
  levelId    Int     @map("level_id")
  isUnlocked Boolean @default(false) @map("is_unlocked")
  unlockedAt  DateTime? @map("unlocked_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId], name: "idx_progress_unique")
  @@index([userId], name: "idx_progress_user")
  @@map("user_progress")
}

model MaterialProgress {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  materialId  Int       @map("material_id")
  isCompleted Boolean   @default(false) @map("is_completed")
  startedAt   DateTime? @map("started_at") @db.Timestamptz(3)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(3)

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId], name: "idx_material_progress_unique")
  @@index([userId], name: "idx_material_progress_user")
  @@map("material_progress")
}

model Assignment {
  id          Int        @id @default(autoincrement())
  userId      Int        @map("user_id")
  levelId     Int        @map("level_id")
  nodeSlot    Int        @map("node_slot") @db.SmallInt
  challengeId Int        @map("challenge_id")
  isCompleted Boolean    @default(false) @map("is_completed")
  assignedAt  DateTime   @default(now()) @map("assigned_at") @db.Timestamptz(3)
  completedAt DateTime?  @map("completed_at") @db.Timestamptz(3)

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     Level     @relation(fields: [levelId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId, nodeSlot], name: "idx_assignment_node_unique")
  @@unique([userId, levelId, challengeId], name: "idx_assignment_challenge_once")
  @@index([userId, levelId], name: "idx_assignment_user_level")
  @@map("assignments")
}

model Attempt {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  challengeId    Int      @map("challenge_id")
  isFirstAttempt Boolean  @map("is_first_attempt")
  timeSpent      Int      @map("time_spent")
  xpEarned       Int      @map("xp_earned") @db.SmallInt
  submittedAt    DateTime @default(now()) @map("submitted_at") @db.Timestamptz(3)

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([userId, challengeId, isFirstAttempt], name: "idx_attempts_first")
  @@index([userId, submittedAt], name: "idx_attempts_history")
  @@index([challengeId], name: "idx_attempts_challenge")
  @@map("attempts")
}

// ============================================
// GAMIFICATION - BADGES
// ============================================

model Badge {
  id             Int      @id @default(autoincrement())
  name           String   @unique @db.VarChar(100)
  description    String   @db.Text
  iconPath       String   @db.VarChar(255)
  rarity         Rarity   @default(COMMON)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // Relations
  userBadges UserBadge[]

  @@map("badges")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY

  @@map("rarity")
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  badgeId  Int      @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at") @db.Timestamptz(3)

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId], name: "idx_user_badge_unique")
  @@index([userId], name: "idx_user_badges_user")
  @@map("user_badges")
}

// ============================================
// User Evaluation - MRC
// ============================================

model MrcWords {
  id          Int      @id @default(autoincrement())
  word        String   @db.VarChar(30)
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  responses         Response[]

  @@map("mrc_words")
}

model Reason {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  reason_text String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("reason")
}

model Response {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  mrcWordId   Int      @map("mrc_word_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mrcWord   MrcWords    @relation(fields: [mrcWordId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mrcWordId])
  @@map("response")
}